{"manifest_version": 3, "name": "Open Directive Guard", "version": "0.1.0", "description": "Do security checks on web3 application, to help aviod becoming a victim to exploits.", "permissions": ["scripting", "activeTab", "tabs"], "host_permissions": ["<all_urls>"], "action": {"default_popup": "html/popup.html"}, "background": {"service_worker": "js/background.js"}, "web_accessible_resources": [{"resources": ["html/*", "css/*", "js/*", "open-directive-icon.png"], "matches": ["<all_urls>"]}]}
